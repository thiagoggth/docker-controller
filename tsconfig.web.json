{
  "extends": "@electron-toolkit/tsconfig/tsconfig.web.json",
  "include": [
    "src/renderer/src/env.d.ts",
    "src/renderer/src/**/*",
    "src/main/shared/**/*",
    "src/main/domain/**/*",
    "src/renderer/src/**/*.tsx",
    "src/preload/*.d.ts"
  ],
  "compilerOptions": {
    "composite": true,
    "jsx": "react-jsx",
    "paths": {
      "@core/*": ["./src/main/*"],
      "@gui/*": ["./src/renderer/src/*"],
      "@preload/*": ["./src/preload/*"]
    }
  }
}
